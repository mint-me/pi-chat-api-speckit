ENVIRONMENT=development
APP_NAME=Chat API

COMPOSE_PROJECT_NAME=pi-chat-api-speckit
API_PORT=8000

POSTGRES_IMAGE=postgres:16-alpine
POSTGRES_DB=pi_chat
POSTGRES_USER=pi_chat_app
POSTGRES_PASSWORD=change-me-local-postgres-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://pi_chat_app:change-me-local-postgres-password@db:5432/pi_chat
TEST_DATABASE_URL=sqlite+aiosqlite:///./.pytest/test.db

JWT_SECRET_KEY=local-development-secret-please-change-12345
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
